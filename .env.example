# App
NODE_ENV=production
APP_DOMAIN=your-app.yourdomain.com
SESSION_SECRET=change-this-to-a-long-random-string

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (Dokploy can provision this)
DATABASE_URL=postgresql://user:pass@host:port/db

# Google Gemini AI
GEMINI_API_KEY=

# Snowflake / Gong Integration (required for Gong tab)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FIVETRAN_DATABASE
SNOWFLAKE_SCHEMA=CLEAN
SNOWFLAKE_WAREHOUSE=
